#################### Define Design Constraints #########################
puts "###############################################"
###############################################
puts "############ Design Constraints #### ##########"
############ Design Constraints #### ##########
puts "###############################################"
###############################################
source -echo ./cons.tcl
####################################################################################
# Constraints
# ----------------------------------------------------------------------------
#
# 0. Design Compiler variables
#
# 1. Master Clock Definitions
#
# 2. Generated Clock Definitions
#
# 3. Clock Uncertainties
#
# 4. Clock Latencies 
#
# 5. Clock Relationships
#
# 6. Set input/output delay on ports
#
# 7. Driving cells
#
# 8. Output load
####################################################################################
#########################################################
#### Section 0 : DC Variables ####
#########################################################
#################################################################################### 
# Prevent assign statements in the generated netlist (must be applied before compile command)
set verilogout_no_tri true
set_fix_multiple_port_nets -all -buffer_constants -feedthroughs
####################################################################################
#########################################################
#### Section 1 : Clock Definition ####
#########################################################
#################################################################################### 
# 1. Master Clock Definitions 
# 2. Generated Clock Definitions
# 3. Clock Latencies
# 4. Clock Uncertainties
# 4. Clock Transitions
####################################################################################
############################     CLOCK PARAMETERS       ############################ 
####################################################################################
#1. REF_CLK (50 MHz) 
set CLK1_NAME REF_CLK
set CLK1_PER 20
#2. UART_CLK (3.686 MHz) 
set CLK2_NAME UART_CLK
set CLK2_PER 271.2673611
#3. SCAN_CLK (10 MHZ)
set CLK3_NAME SCAN_CLK
set CLK3_PER 100
#4. SKEW
set CLK_SETUP_SKEW 0.2
set CLK_HOLD_SKEW 0.1
#5. Transitions
set CLK_RISE 0.05
set CLK_FALL 0.05
set CLK_LAT 0
####################################################################################
#A. Master Clocks
create_clock -name $CLK1_NAME -period $CLK1_PER -waveform "0 [expr $CLK1_PER/2]" [get_ports REF_CLK] ;# -waveform {0 10}
set_clock_uncertainty -setup $CLK_SETUP_SKEW [get_clocks $CLK1_NAME]
set_clock_uncertainty -hold $CLK_HOLD_SKEW  [get_clocks $CLK1_NAME]
create_clock -name $CLK2_NAME -period $CLK2_PER -waveform "0 [expr $CLK2_PER/2]" [get_ports UART_CLK]
set_clock_uncertainty -setup $CLK_SETUP_SKEW [get_clocks $CLK2_NAME]
set_clock_uncertainty -hold $CLK_HOLD_SKEW  [get_clocks $CLK2_NAME]
# set_clock_transition -rise -fall 0.05  [get_clocks $CLK_NAME]
set_clock_transition -rise $CLK_RISE  [get_clocks "$CLK1_NAME $CLK2_NAME"]
set_clock_transition -fall $CLK_FALL  [get_clocks "$CLK1_NAME $CLK2_NAME"]
set_clock_latency $CLK_LAT [get_clocks "$CLK1_NAME $CLK2_NAME"]
#B. Generated clocks
create_generated_clock -master_clock $CLK2_NAME -source [get_ports UART_CLK]                        -name "UART_RX_CLK" [get_port CLK_DIV_RX_UNIT/O_div_clk]                        -divide_by 1
set_clock_uncertainty -setup $CLK_SETUP_SKEW [get_clocks UART_RX_CLK]
set_clock_uncertainty -hold $CLK_HOLD_SKEW   [get_clocks UART_RX_CLK]
create_generated_clock -master_clock $CLK1_NAME -source [get_ports REF_CLK]                        -name "ALU_CLK" [get_port CLOCK_GATE_UNIT/GATED_CLK]                        -divide_by 1
set_clock_uncertainty -setup $CLK_SETUP_SKEW [get_clocks ALU_CLK]
set_clock_uncertainty -hold $CLK_HOLD_SKEW   [get_clocks ALU_CLK]
create_generated_clock -master_clock $CLK2_NAME -source [get_ports UART_CLK]                        -name "UART_TX_CLK" [get_port CLK_DIV_TX_UNIT/O_div_clk]                        -divide_by 32
set_clock_uncertainty -setup $CLK_SETUP_SKEW [get_clocks UART_TX_CLK]
set_clock_uncertainty -hold $CLK_HOLD_SKEW   [get_clocks UART_TX_CLK]
set_clock_transition -rise $CLK_RISE  [get_clocks "ALU_CLK UART_RX_CLK UART_TX_CLK"]
set_clock_transition -fall $CLK_FALL  [get_clocks "ALU_CLK UART_RX_CLK UART_TX_CLK"]
set_clock_latency $CLK_LAT [get_clocks "ALU_CLK UART_RX_CLK UART_TX_CLK"]
#C. Scan clocks
create_clock -name $CLK3_NAME -period $CLK3_PER -waveform "0 [expr $CLK3_PER/2]" [get_ports scan_clk]
set_clock_uncertainty -setup $CLK_SETUP_SKEW [get_clocks $CLK3_NAME]
set_clock_uncertainty -hold $CLK_HOLD_SKEW   [get_clocks $CLK3_NAME]
#set_clock_transition -rise $CLK_RISE  [get_clocks "$CLK3_NAME"]
#set_clock_transition -fall $CLK_FALL  [get_clocks "$CLK3_NAME"]
####################################################################################
#########################################################
#### Section 2 : Clocks Relationship ####
#########################################################
####################################################################################
set_clock_groups -asynchronous -group [get_clocks "$CLK1_NAME ALU_CLK"]                                 -group [get_clocks "$CLK2_NAME UART_TX_CLK UART_RX_CLK"] 			       -group [get_clocks "$CLK3_NAME"]
####################################################################################
#########################################################
#### Section 3 : set input/output delay on ports ####
#########################################################
####################################################################################
set in_delay  [expr 0.2*$CLK2_PER]
set out_delay [expr 0.2*$CLK2_PER]
#Constrain Input Paths
set_input_delay $in_delay -clock $CLK2_NAME [get_ports RX_IN]
#Constrain DFT Input Paths
set_input_delay $in_delay -clock $CLK3_NAME [get_ports SE]
set_input_delay $in_delay -clock $CLK3_NAME [get_ports SI]
set_input_delay $in_delay -clock $CLK3_NAME [get_ports test_mode]
#Constrain Output Paths
set_output_delay $out_delay -clock $CLK2_NAME [get_ports TX_OUT]
set_output_delay $out_delay -clock $CLK2_NAME [get_ports parity_error]
set_output_delay $out_delay -clock $CLK2_NAME [get_ports Stop_Error]
#Constrain DFT Output Paths
set_output_delay $out_delay -clock $CLK3_NAME [get_ports SO]
#set_input_delay $out_delay -clock $CLK2_NAME [get_ports {TX_OUT parity_error Stop_Error}]
####################################################################################
#########################################################
#### Section 4 : Driving cells ####
#########################################################
####################################################################################
set_driving_cell -library scmetro_tsmc_cl013g_rvt_ss_1p08v_125c -lib_cell BUFX2M -pin Y [get_port RX_IN]
Warning: Design rule attributes from the driving cell will be
	set on the port. (UID-401)
set_driving_cell -library scmetro_tsmc_cl013g_rvt_ss_1p08v_125c -lib_cell BUFX2M -pin Y [get_port test_mode]
Warning: Design rule attributes from the driving cell will be
	set on the port. (UID-401)
set_driving_cell -library scmetro_tsmc_cl013g_rvt_ss_1p08v_125c -lib_cell BUFX2M -pin Y [get_port SE]
Warning: Design rule attributes from the driving cell will be
	set on the port. (UID-401)
set_driving_cell -library scmetro_tsmc_cl013g_rvt_ss_1p08v_125c -lib_cell BUFX2M -pin Y [get_port SI]
Warning: Design rule attributes from the driving cell will be
	set on the port. (UID-401)
Warning: Design rule attributes from the driving cell will be
	set on the port. (UID-401)
Warning: Design rule attributes from the driving cell will be
	set on the port. (UID-401)
Warning: Design rule attributes from the driving cell will be
	set on the port. (UID-401)
####################################################################################
#########################################################
#### Section 5 : Output load ####
#########################################################
####################################################################################
set out_load 0.1 ;# 0.1 pf
set_load $out_load [get_port TX_OUT]
set_load $out_load [get_port parity_error]
set_load $out_load [get_port Stop_Error]
#set_load $out_load [get_ports "TX_OUT parity_error Stop_error"]
set_load $out_load [get_port SO]
