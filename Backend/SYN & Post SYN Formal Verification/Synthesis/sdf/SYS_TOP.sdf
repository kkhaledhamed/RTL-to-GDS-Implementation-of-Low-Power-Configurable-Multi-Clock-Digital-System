  (INSTANCE DATA_SYNC_UNIT/sync_reg_reg\[1\])
  (DELAY
    (ABSOLUTE
    (IOPATH (posedge CK) Q (0.383:0.383:0.383) (0.476:0.476:0.476))
    (COND D == 1'b0 && CK == 1'b0 (IOPATH (negedge RN) Q () (0.388:0.388:0.388)))
    (COND D == 1'b1 && CK == 1'b0 (IOPATH (negedge RN) Q () (0.388:0.388:0.388)))
    (COND D == 1'b0 && CK == 1'b1 (IOPATH (negedge RN) Q () (0.384:0.384:0.384)))
    (COND D == 1'b1 && CK == 1'b1 (IOPATH (negedge RN) Q () (0.384:0.384:0.384)))
    )
  )
  (TIMINGCHECK
    (PERIOD CK (1.000:1.000:1.000))
    (SETUP (posedge D) (posedge CK) (0.291:0.291:0.291))
    (SETUP (negedge D) (posedge CK) (0.147:0.147:0.147))
    (HOLD (posedge D) (posedge CK) (-0.167:-0.167:-0.167))
    (HOLD (negedge D) (posedge CK) (-0.019:-0.019:-0.019))
    (SETUP (posedge RN) (posedge CK) (0.392:0.392:0.392))
    (HOLD (posedge RN) (posedge CK) (-0.297:-0.297:-0.297))
  )
)
